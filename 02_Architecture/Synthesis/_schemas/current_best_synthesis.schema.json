{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Current Best Synthesis",
  "type": "object",
  "properties": {
    "synthesis_id": {
      "type": "string",
      "pattern": "^SYN-[0-9]{8}-[A-Z0-9]+$"
    },
    "target_thought_line_id": {
      "type": "string"
    },
    "content_markdown": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["DRAFT", "PUBLISHED", "SUPERSEDED"]
    },
    "generation_date": {
      "type": "string",
      "format": "date-time"
    },
    "authorized_by": {
      "type": "string"
    }
  },
  "required": ["synthesis_id", "target_thought_line_id", "content_markdown", "status", "generation_date", "authorized_by"]
}
