{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/yj000018/yos-cognitive-os/02_Architecture/Synthesis/_schemas/decision_thread.schema.json",
  "title": "DecisionThread",
  "description": "An evolving, reviewable record of a decision in the YOS/KAP cognitive architecture.",
  "type": "object",
  "required": [
    "decision_thread_id",
    "title",
    "decision_text",
    "decision_type",
    "domain",
    "status",
    "decision_status",
    "canonical_status",
    "review_status",
    "current_validity",
    "created_at"
  ],
  "properties": {
    "decision_thread_id": {
      "type": "string",
      "pattern": "^DT-[0-9]{8}-[A-Z0-9]{4}$"
    },
    "title": {
      "type": "string",
      "minLength": 5
    },
    "short_title": {
      "type": "string"
    },
    "decision_text": {
      "type": "string",
      "minLength": 10
    },
    "decision_type": {
      "type": "string",
      "enum": [
        "architecture", "workflow", "tooling", "source_policy", "gate_policy",
        "agent_role", "data_model", "repo_architecture", "security", "privacy",
        "normalization", "merge_policy", "project_direction", "pipeline",
        "automation", "human_ai_exploitation", "unknown"
      ]
    },
    "domain": {
      "type": "string",
      "enum": [
        "YOS", "KAP", "KOSMOS", "CasaTAO", "ELYSIUM", "YOUniverse",
        "Obsidian", "Notion", "Manus", "ChatGPT", "Git", "Automation",
        "Memory", "Agents", "Source_Acquisition", "Synthesis",
        "Repo_Architecture", "Unknown"
      ]
    },
    "scope": { "type": "string" },
    "status": {
      "type": "string",
      "enum": [
        "candidate", "proposed", "accepted", "active", "under_review",
        "superseded", "partially_superseded", "rejected", "deprecated",
        "archived", "requires_review"
      ]
    },
    "decision_status": {
      "type": "string",
      "enum": [
        "not_a_decision", "decision_candidate", "accepted_decision",
        "active_decision", "historical_decision", "superseded_decision",
        "rejected_decision", "deprecated_decision", "requires_review"
      ]
    },
    "canonical_status": {
      "type": "string",
      "enum": [
        "not_canonical", "candidate_evidence", "active_control_plane",
        "historical_source", "implementation_evidence", "superseded_source",
        "requires_review"
      ]
    },
    "review_status": {
      "type": "string",
      "enum": [
        "unreviewed", "metadata_reviewed", "content_reviewed",
        "rationale_reviewed", "alternatives_reviewed", "evidence_reviewed",
        "approved_for_active_control_plane", "approved_for_synthesis_consideration",
        "needs_human_review", "blocked"
      ]
    },
    "current_validity": {
      "type": "string",
      "enum": [
        "active", "active_with_conditions", "historical_context",
        "superseded", "partially_superseded", "rejected", "deprecated",
        "uncertain", "requires_review"
      ]
    },
    "decision_date": { "type": "string", "format": "date-time" },
    "first_seen_at": { "type": "string", "format": "date-time" },
    "last_seen_at": { "type": "string", "format": "date-time" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "decided_by": { "type": "string" },
    "validated_by": { "type": "string" },
    "source_fragment_ids": { "type": "array", "items": { "type": "string" } },
    "claim_ids": { "type": "array", "items": { "type": "string" } },
    "thought_line_ids": { "type": "array", "items": { "type": "string" } },
    "impasse_ids": { "type": "array", "items": { "type": "string" } },
    "related_decision_thread_ids": { "type": "array", "items": { "type": "string" } },
    "parent_decision_thread_id": { "type": "string" },
    "child_decision_thread_ids": { "type": "array", "items": { "type": "string" } },
    "accepted_option": { "type": "string" },
    "rejected_options": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "option": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "alternative_options": { "type": "array", "items": { "type": "string" } },
    "rationale": { "type": "string" },
    "tradeoffs": { "type": "string" },
    "risks": { "type": "string" },
    "assumptions": { "type": "string" },
    "constraints": { "type": "string" },
    "implementation_evidence_ids": { "type": "array", "items": { "type": "string" } },
    "gate_evidence_ids": { "type": "array", "items": { "type": "string" } },
    "mpm_ids": { "type": "array", "items": { "type": "string" } },
    "commit_ids": { "type": "array", "items": { "type": "string" } },
    "supersedes": { "type": "array", "items": { "type": "string" } },
    "superseded_by": { "type": "string" },
    "partially_supersedes": { "type": "array", "items": { "type": "string" } },
    "partially_superseded_by": { "type": "array", "items": { "type": "string" } },
    "contradicts": { "type": "array", "items": { "type": "string" } },
    "supports": { "type": "array", "items": { "type": "string" } },
    "depends_on": { "type": "array", "items": { "type": "string" } },
    "review_required": { "type": "boolean" },
    "next_review_gate": { "type": "string" },
    "confidence_level": {
      "type": "string",
      "enum": ["high", "medium", "low", "unknown"]
    },
    "authority_hint": {
      "type": "string",
      "enum": [
        "user_directive", "guardian_architect_decision", "manus_execution_report",
        "gate_report", "mpm", "git_commit_evidence", "source_document",
        "implementation_evidence", "memory_hint", "external_reference", "unknown"
      ]
    },
    "maturity_hint": {
      "type": "string",
      "enum": [
        "raw", "rough_note", "exploratory", "proposal", "accepted_decision",
        "validated_gate_output", "implementation_evidence", "active_doctrine",
        "canonical_candidate", "deprecated", "unknown"
      ]
    },
    "contradiction_status": {
      "type": "string",
      "enum": [
        "none_known", "contains_contested_claims", "contradicted_by_claim",
        "contradicted_by_decision", "contradicted_by_implementation",
        "internally_inconsistent", "needs_contradiction_review"
      ]
    },
    "supersession_status": {
      "type": "string",
      "enum": [
        "unknown", "active", "historical", "superseded", "partially_superseded",
        "supersedes_other", "partially_supersedes_other", "needs_supersession_review"
      ]
    },
    "merge_status": {
      "type": "string",
      "enum": [
        "not_merged", "candidate_for_merge", "merged_into_parent",
        "split_into_children", "linked_to_thought_line", "eligible_for_synthesis",
        "merge_blocked", "requires_review"
      ]
    },
    "sensitivity_level": {
      "type": "string",
      "enum": [
        "public", "internal", "private", "sensitive",
        "secret_reference_only", "unknown"
      ]
    },
    "human_summary": { "type": "string" },
    "agent_summary": { "type": "string" },
    "review_notes": { "type": "string" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  },
  "additionalProperties": false
}
