{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Evolution Event",
  "type": "object",
  "properties": {
    "event_id": {
      "type": "string",
      "pattern": "^EV-[0-9]{8}-[A-Z0-9]+$"
    },
    "event_type": {
      "type": "string",
      "enum": ["MERGE", "SPLIT", "SUPERSEDE", "DEPRECATE", "VALIDATE"]
    },
    "target_id": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "rationale": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["event_id", "event_type", "target_id", "rationale", "timestamp"]
}
